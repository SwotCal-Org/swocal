# Server-side / backend secrets — NEVER ship in mobile bundle.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

OPENWEATHER_API_KEY=
ANTHROPIC_API_KEY=
# OpenRouter: GenUI coupon detail (mobile uses EXPO_PUBLIC_*; edge function uses server secret)
OPENROUTER_API_KEY=
EXPO_PUBLIC_OPENROUTER_API_KEY=
GOOGLE_MAPS_API_KEY= 
# Rotated Key.
# Dev-only client fallback (unsafe for production; exposed to app bundle).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
